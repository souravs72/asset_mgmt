{
 "custom_fields": [
  {
   "dt": "Asset",
   "fieldname": "asset_tagging_section",
   "fieldtype": "Section Break",
   "insert_after": "status",
   "label": "Asset Tagging"
  },
  {
   "dt": "Asset",
   "fieldname": "asset_tag",
   "fieldtype": "Data",
   "insert_after": "asset_tagging_section",
   "in_list_view": 1,
   "in_standard_filter": 1,
   "label": "Asset Tag",
   "description": "Barcode / RFID / QR code",
   "unique": 1
  },
  {
   "dt": "Asset",
   "fieldname": "asset_tag_type",
   "fieldtype": "Select",
   "insert_after": "serial_number",
   "label": "Tag Type",
   "options": "Barcode\nRFID\nQR"
  },
  {
   "dt": "Asset",
   "fieldname": "serial_number",
   "fieldtype": "Data",
   "insert_after": "asset_tag",
   "in_list_view": 1,
   "label": "Serial Number"
  },
  {
   "dt": "Asset",
   "fieldname": "operational_status",
   "fieldtype": "Select",
   "insert_after": "asset_tag_type",
   "in_list_view": 1,
   "in_standard_filter": 1,
   "label": "Operational Status",
   "options": "Active\nUnder Maintenance\nRetired\nLost",
   "default": "Active"
  },
  {
   "dt": "Asset",
   "fieldname": "legacy_asset_code",
   "fieldtype": "Data",
   "insert_after": "operational_status",
   "label": "Legacy Asset Code",
