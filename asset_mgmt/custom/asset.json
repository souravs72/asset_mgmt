  },
  {
   "dt": "Asset",
   "fieldname": "legacy_category",
   "fieldtype": "Data",
   "insert_after": "legacy_group",
   "label": "Legacy Category"
  },
  {
   "dt": "Asset",
   "fieldname": "legacy_subcategory",
   "fieldtype": "Data",
   "insert_after": "legacy_category",
   "label": "Legacy Sub Category"
  },
  {
   "dt": "Asset",
   "fieldname": "asset_condition",
   "fieldtype": "Select",
   "insert_after": "legacy_subcategory",
   "in_standard_filter": 1,
   "label": "Asset Condition",
   "options": "In Service\nDamaged\nNot in Use\nSold\nScrapped"
  },
  {
   "dt": "Asset",
   "fieldname": "legacy_import_notes",
   "fieldtype": "Small Text",
   "insert_after": "asset_condition",
   "label": "Legacy Import Notes",
   "read_only": 1
  }
 ],
